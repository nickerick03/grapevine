{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["vite/client"]
  },
  "include": [
    "src/main.tsx",
    "src/app/App.tsx",
    "src/app/Root.tsx",
    "src/app/context/**/*",
    "src/app/pages/**/*",
    "src/app/components/AuthModal.tsx",
    "src/components/**/*",
    "src/lib/**/*",
    "src/types/**/*",
    "src/vite-env.d.ts"
  ]
}
